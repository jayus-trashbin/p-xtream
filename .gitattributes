# Normalize line endings to LF on commit, checkout as CRLF on Windows
* text=auto eol=lf

# Force LF for shell scripts and config files
*.sh text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.prisma text eol=lf
*.sql text eol=lf
*.env.example text eol=lf
Dockerfile text eol=lf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.mp4 binary
*.webm binary
*.pdf binary
