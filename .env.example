# ================================================================
# P-STREAM MONOREPO — Environment Variables
# ================================================================
# Copy this file to .env and fill in your values.
# Lines marked ✅ are REQUIRED. Lines marked ⬜ are optional.
# ================================================================

# ── DATABASE ─────────────────────────────────────────────────────
# ✅ PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pstream"

# ── BACKEND AUTH ──────────────────────────────────────────────────
# ✅ HS256 JWT signing key — minimum 32 chars, max 64 chars
# Generate: openssl rand -hex 32
CRYPTO_SECRET=""

# ✅ Comma-separated allowed CORS origins (no trailing slash)
# Example: "http://localhost:5173,https://yourdomain.com"
ALLOWED_ORIGINS="http://localhost:5173"

# ── PROXY AUTH ────────────────────────────────────────────────────
# ✅ Must match CRYPTO_SECRET — proxy validates JWTs signed by backend
JWT_SECRET=""

# ── TMDB ─────────────────────────────────────────────────────────
# ✅ Server-side TMDB API key (backend only — never expose to client)
TMDB_API_KEY=""

# ✅ Client-side TMDB API key (embedded in web build — can be same key)
VITE_TMDB_API_KEY=""

# ── TRAKT (optional) ──────────────────────────────────────────────
# ⬜ Trakt OAuth client credentials
# Without these, discover page uses TMDB only (no crash — graceful fallback)
TRAKT_CLIENT_ID=""
TRAKT_CLIENT_SECRET=""
VITE_TRAKT_CLIENT_ID=""

# ── PROXY ─────────────────────────────────────────────────────────
# ✅ CORS proxy base URL (used by web to proxy media requests)
VITE_PROXY_URL="http://localhost:3001"

# ✅ M3U8 proxy base URL (used for HLS stream proxying)
# Can be the same host as VITE_PROXY_URL
VITE_M3U8_PROXY_URL="http://localhost:3001"

# ✅ Origins the proxy accepts requests from
PROXY_CORS_ALLOWED_ORIGINS="http://localhost:5173"

# ⬜ M3U8 cache memory limit in MB (default: 512)
CACHE_MAX_MEMORY_MB=512

# ⬜ Enable .ts segment prefetching (default: true)
# Set to false if the proxy is using too much bandwidth
PREFETCH_ENABLED=true

# ⬜ Max concurrent prefetch requests per stream (default: 3)
PREFETCH_CONCURRENCY=3

# ⬜ Rate limit: max requests per minute per IP (default: 100)
RATE_LIMIT_RPM=100

# ── METRICS ───────────────────────────────────────────────────────
# ⬜ Bearer token for the /metrics Prometheus endpoint
# Strongly recommended in production — leave empty to keep the endpoint open
# Generate: openssl rand -hex 32
METRICS_TOKEN=""

# ── CLOUDFLARE TURNSTILE (optional) ───────────────────────────────
# ⬜ Server-side Turnstile secret (backend)
TURNSTILE_SECRET=""

# ⬜ Client-side Turnstile site key (web)
VITE_TURNSTILE_SITE_KEY=""

# ── ANALYTICS (optional) ──────────────────────────────────────────
# ⬜ Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_ID=""

# ── FEATURE FLAGS ─────────────────────────────────────────────────
# ⬜ Enable/disable Watch Party feature in the UI
VITE_ENABLE_WATCH_PARTY=true

# ⬜ Enable/disable Trakt sync feature in the UI
VITE_ENABLE_TRAKT=false

# ── BACKEND URL ───────────────────────────────────────────────────
# ✅ Backend API base URL (used by web build at compile time)
VITE_BACKEND_URL="http://localhost:3000"

# ── REDIS (Phase 2 — Watch Party WebSocket) ───────────────────────
# ⬜ Will be required when Watch Party migrates to WebSocket + Redis
# REDIS_URL="redis://localhost:6379"
