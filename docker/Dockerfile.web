# ── P-Stream Web — Multi-stage monorepo Dockerfile ────────────────────────────
# Build context: repo root (../ from docker/)
# Usage: docker build -f docker/Dockerfile.web \
#          --build-arg VITE_TMDB_API_KEY=xxx \
#          --build-arg VITE_BACKEND_URL=https://api.example.com \
#          --build-arg VITE_PROXY_URL=https://proxy.example.com \
#          -t p-stream-web .
# ──────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Base ─────────────────────────────────────────────────────────────
FROM node:20-alpine AS base
RUN npm install -g pnpm@9

# ── Stage 2: Deps ─────────────────────────────────────────────────────────────
FROM base AS deps
WORKDIR /app

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/
# providers is a local dep of web
COPY packages/providers/package.json packages/providers/

RUN pnpm install --frozen-lockfile --filter @p-stream/web...

# ── Stage 3: Build ────────────────────────────────────────────────────────────
FROM base AS build
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules 2>/dev/null || true
COPY --from=deps /app/packages/shared/node_modules ./packages/shared/node_modules 2>/dev/null || true
COPY --from=deps /app/packages/providers/node_modules ./packages/providers/node_modules 2>/dev/null || true

COPY apps/web ./apps/web
COPY packages/shared ./packages/shared
COPY packages/providers ./packages/providers

# ── Build-time Vite env vars ─────────────────────────────────────────────────
# All VITE_ vars are baked into the static bundle at build time.
ARG VITE_TMDB_API_KEY
ARG VITE_TMDB_READ_API_KEY
ARG VITE_BACKEND_URL
ARG VITE_PROXY_URL
ARG VITE_M3U8_PROXY_URL
ARG VITE_PWA_ENABLED=true
ARG VITE_ALLOW_AUTOPLAY=false
ARG VITE_GA_ID
ARG VITE_APP_DOMAIN
ARG VITE_TURNSTILE_SITE_KEY

ENV VITE_TMDB_API_KEY=${VITE_TMDB_API_KEY}
ENV VITE_TMDB_READ_API_KEY=${VITE_TMDB_READ_API_KEY}
ENV VITE_BACKEND_URL=${VITE_BACKEND_URL}
ENV VITE_PROXY_URL=${VITE_PROXY_URL}
ENV VITE_M3U8_PROXY_URL=${VITE_M3U8_PROXY_URL}
ENV VITE_PWA_ENABLED=${VITE_PWA_ENABLED}
ENV VITE_ALLOW_AUTOPLAY=${VITE_ALLOW_AUTOPLAY}
ENV VITE_GA_ID=${VITE_GA_ID}
ENV VITE_APP_DOMAIN=${VITE_APP_DOMAIN}
ENV VITE_TURNSTILE_SITE_KEY=${VITE_TURNSTILE_SITE_KEY}

WORKDIR /app/apps/web
# Build packages/providers first (local workspace dep)
WORKDIR /app/packages/providers
RUN pnpm build

WORKDIR /app/apps/web
RUN pnpm build

# ── Stage 4: Nginx runtime ────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# Copy built assets
COPY --from=build /app/apps/web/dist /usr/share/nginx/html

# Custom nginx config for SPA (React Router) — serves index.html for all routes
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
