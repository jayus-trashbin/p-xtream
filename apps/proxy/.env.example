# =============================================================
# P-Stream Proxy — Environment Variables
# =============================================================
# Copy this file to .env and fill in the required values.
# =============================================================

# ── SERVER ─────────────────────────────────────────────────────
# ✅ REQUIRED: Port the proxy listens on
NITRO_PORT=3005

# ── SECURITY ───────────────────────────────────────────────────
# ✅ REQUIRED: JWT signing secret — must match CRYPTO_SECRET in the backend
#    Generated with: openssl rand -hex 32
JWT_SECRET=

# ── CACHE ──────────────────────────────────────────────────────
# ⬜ OPTIONAL: Enable in-memory M3U8 segment cache (default: true)
ENABLE_CACHE=true

# ⬜ OPTIONAL: Max memory used for cache in MB (default: 512)
CACHE_MAX_MEMORY_MB=512

# ⬜ OPTIONAL: Disable M3U8 proxying entirely (default: false)
DISABLE_M3U8=false

# ── CLOUDFLARE TURNSTILE (optional) ───────────────────────────
# ⬜ OPTIONAL: Turnstile secret for bot protection
#    Leave empty to disable Turnstile validation
TURNSTILE_SECRET=

# ── DEBUG ──────────────────────────────────────────────────────
# ⬜ OPTIONAL: Enable verbose request logging (default: false)
REQ_DEBUG=false
