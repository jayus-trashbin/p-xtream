# =============================================================
# P-Stream Web App — Environment Variables
# =============================================================
# Copy this file to .env and fill in the required values.
# =============================================================

# ── TMDB ─────────────────────────────────────────────────────
# ✅ REQUIRED: Your TMDB v4 Read Access Token (recommended)
#    OR a v3 API key (shorter alphanumeric string)
#    Get yours at: https://www.themoviedb.org/settings/api
VITE_TMDB_READ_API_KEY=

# ── PROXY ─────────────────────────────────────────────────────
# ✅ REQUIRED: Base URL of the running CORS proxy service
#    Do NOT include a trailing slash
VITE_CORS_PROXY_URL=http://localhost:3005

# ✅ REQUIRED: Base URL of the M3U8 (HLS) proxy service
#    Can be the same as VITE_CORS_PROXY_URL
VITE_M3U8_PROXY_URL=http://localhost:3005

# ── BACKEND ────────────────────────────────────────────────────
# ✅ REQUIRED: Base URL of the backend API
#    Supports multiple comma-separated URLs for load balancing
#    Example: "https://api1.example.com,https://api2.example.com"
VITE_BACKEND_URL=http://localhost:3001

# ── APP DOMAIN ─────────────────────────────────────────────────
# ✅ REQUIRED: Public domain of this web app
#    Do NOT include a trailing slash
VITE_APP_DOMAIN=http://localhost:5173

# ── TRAKT (optional) ──────────────────────────────────────────
# ⬜ OPTIONAL: Trakt OAuth credentials for sync features
#    Register at: https://trakt.tv/oauth/applications
VITE_TRAKT_CLIENT_ID=
VITE_TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=http://localhost:5173

# ── OPENSEARCH (optional) ─────────────────────────────────────
# ⬜ OPTIONAL: Enable browser OpenSearch integration
VITE_OPENSEARCH_ENABLED=false
